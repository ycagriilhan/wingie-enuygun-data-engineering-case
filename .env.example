# Optional runtime mode: local or cloud
WEG_RUN_MODE=local

# Optional cloud placeholders for future phases
GCS_BUCKET=
GCP_PROJECT_ID=
GCS_LANDING_PREFIX=landing
GCP_BQ_LOCATION=EU
GCP_DATASET_RAW=raw
GCP_DATASET_STAGING=staging
GCP_DATASET_MART=mart

# Optional feature toggles (Phase 1 optional scaffolding)
WEG_ENABLE_MERGE_UPSERT=false
WEG_ENABLE_AIRFLOW=false

# Optional reserved paths (kept for future optional phases)
WEG_SQL_OPTIONAL_DIR=sql/optional
WEG_AIRFLOW_DAGS_DIR=orchestration/airflow/dags
